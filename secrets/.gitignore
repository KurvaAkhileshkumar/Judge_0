# Secrets directory — actual secret files are gitignored.
# Create each file with your real secret value (no trailing newline needed).
#
#   echo -n "your-strong-redis-password"    > secrets/redis_password
#   echo -n "your-strong-postgres-password" > secrets/postgres_password
#   echo -n "$(openssl rand -hex 64)"       > secrets/rails_secret_key
#
# These files are mounted into containers by docker-compose.yml.
# Never commit actual secret values to version control.

# Ignore everything in this directory …
*
# … except this file and placeholder stubs
!.gitignore
!redis_password.example
!postgres_password.example
!rails_secret_key.example
