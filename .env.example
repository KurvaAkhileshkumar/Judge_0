# .env.example — copy to .env and fill in real values
# Docker Compose loads .env automatically; values substitute ${VAR} in docker-compose.yml.
# NEVER commit .env with real secrets to version control.
#
# Quick setup:
#   cp .env.example .env
#   # Edit .env with strong random values
#   # For REDIS_PASSWORD / POSTGRES_PASSWORD: use `openssl rand -base64 32`
#   # For RAILS_SECRET_KEY_BASE:              use `openssl rand -hex 64`

REDIS_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
RAILS_SECRET_KEY_BASE=CHANGE_ME_OUTPUT_OF_openssl_rand_hex_64

# Optional: require a bearer token on GET /health
# Leave unset to allow unauthenticated health checks (suitable for internal networks only).
# HEALTH_TOKEN=CHANGE_ME_STRONG_RANDOM_TOKEN
